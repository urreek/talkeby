{
  "name": "talkeby",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node scripts/ensure-native.mjs && node --env-file=.env src/server.mjs",
    "dev": "node scripts/ensure-native.mjs && node --env-file=.env --watch src/server.mjs",
    "dev:web": "npm --prefix web run dev",
    "web:dev": "npm --prefix web run dev",
    "web:install": "npm --prefix web install",
    "web:build": "npm --prefix web run build",
    "web:check": "npm --prefix web run check",
    "setup:guided": "node scripts/talkeby-cli.mjs install",
    "doctor": "node scripts/talkeby-cli.mjs doctor",
    "check": "node --check scripts/ensure-native.mjs && node --check src/server.mjs && node --check src/http/routes.mjs && node --check src/http/jobs-routes.mjs && node --check src/http/events-route.mjs && node --check src/http/shared.mjs && node --check src/telegram/worker.mjs && node --check src/telegram/command-handler.mjs && node --check src/telegram/formatters.mjs",
    "launchd:install": "bash ./scripts/install-launchd.sh",
    "launchd:uninstall": "bash ./scripts/uninstall-launchd.sh"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "zod": "^4.1.12"
  }
}

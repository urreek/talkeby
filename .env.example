PORT=3000
DATA_DIR=/Users/your-user/.talkeby
DATABASE_FILE=/Users/your-user/.talkeby/talkeby.db

TELEGRAM_BOT_TOKEN=123456789:YOUR_BOT_TOKEN
TELEGRAM_ALLOWED_CHAT_IDS=123456789
# If true, any chat can run jobs. Keep false in production.
ALLOW_UNVERIFIED_CHATS=false
# Default behavior for new chats: auto or interactive.
TELEGRAM_DEFAULT_EXECUTION_MODE=auto
# Optional second factor on every command:
# COMMAND_PIN=2468
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_RETRY_DELAY_MS=1500
# Drop old queued Telegram messages when the worker starts.
TELEGRAM_DROP_PENDING_UPDATES=true
# Send periodic "still running" messages while Codex is working.
TELEGRAM_PROGRESS_UPDATES=true
TELEGRAM_PROGRESS_UPDATE_SECONDS=60

CODEX_BINARY=/Applications/Codex.app/Contents/Resources/codex
CODEX_WORKDIR=/Users/your-user/path/to/repo-you-want-coded
# Optional multi-project setup (comma-separated name=path):
# CODEX_PROJECTS=web=/Users/your-user/dev/web,api=/Users/your-user/dev/api
# Optional default project name from CODEX_PROJECTS (falls back to first entry):
# CODEX_DEFAULT_PROJECT=web
CODEX_TIMEOUT_MS=900000
# Optional:
# CODEX_MODEL=o3

PORT=3000
WEB_PORT=5173
DATA_DIR=/Users/your-user/.talkeby
DATABASE_FILE=/Users/your-user/.talkeby/talkeby.db
API_RATE_LIMIT_PER_MINUTE=240

# Required before exposing Talkeby outside your local network.
APP_ACCESS_KEY=choose-a-long-random-secret
# Optional explicit CSRF secret. If omitted, a deterministic local secret is derived.
# CSRF_SECRET=replace-me
CSRF_TTL_SECONDS=43200
SESSION_TTL_SECONDS=2592000

DEFAULT_EXECUTION_MODE=auto
PROGRESS_UPDATES=true
PROGRESS_UPDATE_SECONDS=60

RUNTIME_POLICY_ENABLED=true
# If true, all runtime approval prompts are auto-approved immediately.
RUNTIME_POLICY_AUTO_APPROVE_ALL=true
# If true, file changes require explicit runtime approval. If false, file changes are auto-approved.
RUNTIME_POLICY_FILE_CHANGES_REQUIRE_APPROVAL=false

# Optional web dev/tunnel port (used by tunnel helper scripts)
# WEB_PORT=5173

# Keep portable default. Optional absolute path also works (e.g. macOS app bundle path).
CODEX_BINARY=codex
CODEX_WORKDIR=/Users/your-user/path/to/repo-you-want-coded
CODEX_PROJECTS_BASE_DIR=/Users/your-user/dev
# Optional multi-project setup (comma-separated name=path):
# CODEX_PROJECTS=web=/Users/your-user/dev/web,api=/Users/your-user/dev/api
# Optional default project name from CODEX_PROJECTS (falls back to first entry):
# CODEX_DEFAULT_PROJECT=web
CODEX_TIMEOUT_MS=900000
# Parity mode makes Talkeby send only the raw user message to Codex (no Talkeby-added context).
CODEX_PARITY_MODE=true
# Runtime history persistence for Codex session resume.
CODEX_PERSIST_EXTENDED_HISTORY=true
# If true, Talkeby will not resume previous Codex session IDs across runs.
CODEX_DISABLE_SESSION_RESUME=false
THREAD_DEFAULT_TOKEN_BUDGET=10000
THREAD_AUTO_TRIM_CONTEXT_DEFAULT=true
# Optional:
# CODEX_MODEL=o3

# Provider selection (codex|claude|gemini|groq|openrouter)
AI_PROVIDER=codex
# Optional explicit model override for selected provider:
# AI_MODEL=
CLAUDE_BINARY=claude
GEMINI_BINARY=gemini
AIDER_BINARY=aider

# API keys for non-Codex providers:
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# Enforce free-only models where free-safe lists are defined.
FREE_MODELS_ONLY=true
# If true, provider model dropdowns include dynamic account/network discovery.
PROVIDER_MODEL_DISCOVERY=true

# Debug logging (off by default). Useful for inspecting the exact outbound prompt
# and provider token usage returned per job.
DEBUG_LOG_PROMPT_PAYLOAD=false
DEBUG_LOG_TOKEN_USAGE=false

PORT=3000
DATA_DIR=/Users/your-user/.talkeby
DATABASE_FILE=/Users/your-user/.talkeby/talkeby.db
API_RATE_LIMIT_PER_MINUTE=240
# Optional app-level access key for web/API access (recommended when exposed publicly).
# APP_ACCESS_KEY=choose-a-long-random-secret
# Optional default web identity. When APP_ACCESS_KEY is valid and chatId is omitted,
# this chat is used automatically for web requests.
# OWNER_CHAT_ID=123456789
# Optional explicit CSRF secret. If omitted, a deterministic local secret is derived.
# CSRF_SECRET=replace-me
CSRF_TTL_SECONDS=43200
RUNTIME_POLICY_ENABLED=true
# If true, all runtime approval prompts are auto-approved immediately.
RUNTIME_POLICY_AUTO_APPROVE_ALL=true
# If true, file changes require explicit runtime approval. If false, file changes are auto-approved.
RUNTIME_POLICY_FILE_CHANGES_REQUIRE_APPROVAL=false
# If true, sends runtime approval prompts to Telegram chat as well.
# Keep false to avoid approval spam in chat and approve from the web UI cards only.
RUNTIME_APPROVAL_TELEGRAM_NOTIFICATIONS=false

TELEGRAM_BOT_TOKEN=123456789:YOUR_BOT_TOKEN
TELEGRAM_ALLOWED_CHAT_IDS=123456789
# If true, any chat can run jobs. Keep false in production.
ALLOW_UNVERIFIED_CHATS=false
# Default behavior for new chats: auto or interactive.
TELEGRAM_DEFAULT_EXECUTION_MODE=auto
# Force auto mode globally (recommended to avoid all pre-run approvals).
FORCE_AUTO_MODE=true
# Optional second factor on every command:
# COMMAND_PIN=2468
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_RETRY_DELAY_MS=1500
# Drop old queued Telegram messages when the worker starts.
TELEGRAM_DROP_PENDING_UPDATES=true
# Send periodic "still running" messages while Codex is working.
TELEGRAM_PROGRESS_UPDATES=true
TELEGRAM_PROGRESS_UPDATE_SECONDS=60

CODEX_BINARY=/Applications/Codex.app/Contents/Resources/codex
CODEX_WORKDIR=/Users/your-user/path/to/repo-you-want-coded
CODEX_PROJECTS_BASE_DIR=/Users/your-user/dev
# Optional multi-project setup (comma-separated name=path):
# CODEX_PROJECTS=web=/Users/your-user/dev/web,api=/Users/your-user/dev/api
# Optional default project name from CODEX_PROJECTS (falls back to first entry):
# CODEX_DEFAULT_PROJECT=web
CODEX_TIMEOUT_MS=900000
THREAD_DEFAULT_TOKEN_BUDGET=10000
THREAD_AUTO_TRIM_CONTEXT_DEFAULT=true
# Optional:
# CODEX_MODEL=o3

# Provider selection (codex|claude|gemini|groq|openrouter)
AI_PROVIDER=codex
# Optional explicit model override for selected provider:
# AI_MODEL=
CLAUDE_BINARY=claude
GEMINI_BINARY=gemini
AIDER_BINARY=aider

# API keys for non-Codex providers:
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# Enforce free-only models where free-safe lists are defined.
FREE_MODELS_ONLY=true
